{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": [
    "package.json"
  ],
  "envMode": "loose",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputLogs": "new-only",
      "outputs": ["dist/**"]
    },
    "source": {
      "dependsOn": ["^source"]
    }
  }
}